DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Intelligent Transaction Import (ITI)
OPENAI_API_KEY=
ITI_PROVIDER=openai
ITI_OPENAI_MODEL=gpt-4o
ITI_PDF_PROCESSING_MODE=openai_file

# Vercel Blob — OIDC-connected stores (recommended on Vercel)
BLOB_STORE_ID=
BLOB_WEBHOOK_PUBLIC_KEY=
# Match your connected Blob store access mode: public or private (default: private)
BLOB_ACCESS_MODE=private

# Legacy token auth (optional — not required for OIDC-connected projects)
# BLOB_READ_WRITE_TOKEN=

# Document storage (legacy local dev fallback for non-ITI paths)
DOCUMENT_STORAGE_PROVIDER=local
