DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Intelligent Transaction Import (ITI)
OPENAI_API_KEY=
ITI_PROVIDER=openai

# Vercel Blob — direct client uploads for ITI documents
BLOB_READ_WRITE_TOKEN=
# Match your connected Blob store access mode: public or private (default: private)
BLOB_ACCESS_MODE=private

# Document storage (legacy local dev fallback for non-ITI paths)
DOCUMENT_STORAGE_PROVIDER=local
